.page {
  padding: 20rpx 20rpx 160rpx;
}

.form-row {
  display: flex;
  gap: 20rpx;
}
.flex-1 { flex: 1; }

/* 快速方案 */
.preset-bar {
  margin-bottom: 20rpx;
}
.preset-label {
  display: block;
  font-size: 24rpx;
  color: #8c8c8c;
  margin-bottom: 10rpx;
}
.preset-scroll {
  width: 100%;
  white-space: nowrap;
}
.preset-inner {
  display: inline-flex;
  gap: 12rpx;
}
.preset-btn {
  display: inline-block;
  padding: 12rpx 24rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  background: #e8f8ee;
  color: #07c160;
  white-space: nowrap;
  border: none;
}
.preset-btn:active { opacity: 0.7; }

/* 分成输入 */
.share-inputs {
  margin-bottom: 8rpx;
}
.share-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
}
.share-label {
  width: 70rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a1a;
}
.share-control {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 6rpx;
}
.share-input {
  flex: 1;
  height: 56rpx;
  padding: 0 16rpx !important;
  line-height: 56rpx !important;
}
.share-pct {
  font-size: 24rpx;
  color: #c0c0c0;
  width: 30rpx;
}
.share-amount {
  width: 130rpx;
  text-align: right;
  font-size: 26rpx;
  font-weight: 600;
  color: #07c;
}

/* 提交按钮 */
.form-actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 32rpx;
}
.form-actions .btn {
  padding: 24rpx;
  font-size: 30rpx;
}
