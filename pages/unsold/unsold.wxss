.page {
  padding: 20rpx 20rpx 160rpx;
}

/* 统计卡片 */
.stats-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 20rpx;
}
.stat-item {
  width: calc(50% - 6rpx);
  border-radius: 16rpx;
  padding: 20rpx 16rpx;
  color: #fff;
  box-sizing: border-box;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.stat-num {
  display: block;
  font-size: 36rpx;
  font-weight: 800;
}
.stat-label {
  display: block;
  font-size: 22rpx;
  opacity: 0.85;
  margin-top: 4rpx;
}
.bg-unsold { background: linear-gradient(135deg, #ff9300, #ffb74d); }
.bg-selling { background: linear-gradient(135deg, #07c160, #4cda7a); }
.bg-sold { background: linear-gradient(135deg, #b0b0b0, #d0d0d0); }
.bg-cost { background: linear-gradient(135deg, #1989fa, #5baafb); }

/* 时间筛选 */
.date-filter {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}
.date-pick {
  flex: 1;
  padding: 14rpx 16rpx;
  background: #fff;
  border-radius: 12rpx;
  font-size: 24rpx;
  color: #c0c0c0;
  text-align: center;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.date-pick.active { color: #1a1a1a; }
.date-sep { font-size: 24rpx; color: #c0c0c0; }
.date-clear {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: #8c8c8c;
}

/* 搜索 */
.search-wrap { margin-bottom: 16rpx; }
.search-box {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 0 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.search-icon { font-size: 28rpx; margin-right: 12rpx; }
.search-input {
  flex: 1;
  height: 72rpx;
  font-size: 26rpx;
}
.search-clear {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: #8c8c8c;
}

/* 控制栏 */
.control-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.picker-filter {
  padding: 12rpx 24rpx;
  background: #f0f0f0;
  border-radius: 30rpx;
  font-size: 26rpx;
  font-weight: 500;
  color: #1a1a1a;
}

/* 商品列表 */
.item-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.item-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.item-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 14rpx;
}
.item-top-left {
  display: flex;
  align-items: flex-start;
  flex: 1;
  min-width: 0;
}
.item-name-wrap {
  flex: 1;
  min-width: 0;
}
.sel-box {
  width: 40rpx;
  height: 40rpx;
  border-radius: 8rpx;
  border: 3rpx solid #d0d0d0;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
}
.sel-box.on {
  background: #07c160;
  border-color: #07c160;
}
.sel-box:active { opacity: 0.7; }
.check-icon { font-size: 26rpx; color: #fff; font-weight: 700; }

.batch-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 12rpx;
  padding-top: 12rpx;
  border-top: 2rpx solid #eee;
}
.batch-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.batch-select-all {
  padding: 6rpx 20rpx;
  font-size: 24rpx;
  color: #1989fa;
  background: #f0f7ff;
  border-radius: 6rpx;
}
.batch-select-all:active { opacity: 0.7; }
.batch-count {
  font-size: 24rpx;
  color: #8c8c8c;
}
.item-order {
  font-size: 22rpx;
  color: #c0c0c0;
  margin-right: 8rpx;
  font-weight: 500;
}
.item-source {
  font-size: 20rpx;
  color: #1989fa;
  background: #f0f7ff;
  padding: 2rpx 12rpx;
  border-radius: 6rpx;
  margin-left: 8rpx;
  flex-shrink: 0;
}
.item-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a1a;
  flex: 1;
  margin-right: 12rpx;
}
.status-badge {
  padding: 8rpx 24rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1.4;
  white-space: nowrap;
}
.status-badge.status-unsold { background: #fff3e0; color: #ff9300; }
.status-badge.status-selling { background: #e8f8ee; color: #07c160; }
.status-badge.status-sold { background: #e8e8e8; color: #8c8c8c; }

.item-meta {
  display: flex;
  gap: 0;
  padding: 14rpx 0;
  border-top: 2rpx solid #eee;
  border-bottom: 2rpx solid #eee;
  margin-bottom: 14rpx;
}
.meta-col {
  flex: 1;
  text-align: center;
}
.meta-col + .meta-col { border-left: 2rpx solid #eee; }
.m-label {
  display: block;
  font-size: 22rpx;
  color: #8c8c8c;
  margin-bottom: 4rpx;
}
.m-value {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #1a1a1a;
}
.m-rate {
  display: block;
  font-size: 20rpx;
  color: #07c160;
  margin-top: 2rpx;
}
.m-input {
  width: 90%;
  padding: 8rpx;
  border: 2rpx solid #eee;
  border-radius: 6rpx;
  font-size: 24rpx;
  text-align: center;
  background: #fafafa;
}

.item-footer {
  display: flex;
  justify-content: flex-end;
  align-items: center;
}
.item-actions {
  display: flex;
  gap: 14rpx;
}
.act-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 12rpx 28rpx;
  border-radius: 36rpx;
  font-size: 24rpx;
  font-weight: 500;
  border: none;
  line-height: 1.3;
}
.act-edit {
  background: #f5f5f5;
  color: #8c8c8c;
  border: 2rpx solid #e8e8e8;
}
.act-edit:active { background: #e8e8e8; }
.act-del {
  background: #fff0f0;
  color: #fa5151;
  border: 2rpx solid #ffdddd;
}
.act-del:active { background: #ffe0e0; }

/* Modal */
.modal-desc {
  display: block;
  font-size: 26rpx;
  color: #8c8c8c;
  text-align: center;
  margin-bottom: 24rpx;
}
.modal-options {
  display: flex;
  gap: 12rpx;
  margin-bottom: 8rpx;
}
.modal-option {
  flex: 1;
  text-align: center;
  padding: 24rpx 8rpx;
  border: 3rpx solid #eee;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #8c8c8c;
}
.modal-option.active {
  border-color: #07c160;
  background: #e8f8ee;
  color: #07c160;
}
.opt-icon {
  display: block;
  font-size: 36rpx;
  margin-bottom: 8rpx;
}

