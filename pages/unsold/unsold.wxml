<view class="page">

  <view class="stats-grid">
    <view class="stat-item bg-unsold">
      <text class="stat-num">{{stats.unsold}}</text>
      <text class="stat-label">未售出</text>
    </view>
    <view class="stat-item bg-selling">
      <text class="stat-num">{{stats.selling}}</text>
      <text class="stat-label">在售中</text>
    </view>
    <view class="stat-item bg-sold">
      <text class="stat-num">{{stats.sold}}</text>
      <text class="stat-label">已售出</text>
    </view>
    <view class="stat-item bg-cost">
      <text class="stat-num">¥{{stats.totalCostText}}</text>
      <text class="stat-label">总成本</text>
    </view>
  </view>

  <view class="date-filter">
    <picker mode="date" bindchange="onDateStartChange">
      <view class="date-pick {{dateStart ? 'active' : ''}}">{{dateStart || '开始日期'}}</view>
    </picker>
    <text class="date-sep">～</text>
    <picker mode="date" bindchange="onDateEndChange">
      <view class="date-pick {{dateEnd ? 'active' : ''}}">{{dateEnd || '结束日期'}}</view>
    </picker>
    <view class="date-clear" wx:if="{{dateStart || dateEnd}}" bindtap="clearDateFilter">✕</view>
  </view>

  <view class="search-wrap">
    <view class="search-box">
      <text class="search-icon">🔍</text>
      <input class="search-input" placeholder="搜索商品名称" bindinput="onSearchInput" value="{{searchKeyword}}" />
      <text class="search-clear" wx:if="{{searchKeyword}}" bindtap="clearSearch">✕</text>
    </view>
  </view>

  <view class="card">
    <view class="control-bar">
      <picker range="{{filterOptions}}" range-key="text" bindchange="setStatusFilter">
        <view class="picker-filter">状态：{{filterOptions[filterIndex].text}} ▾</view>
      </picker>
      <button class="btn btn-sm {{batchMode ? 'btn-orange' : 'btn-blue'}}" wx:if="{{statusFilter === 'unsold' || statusFilter === 'selling'}}" bindtap="toggleBatch">{{batchMode ? '取消' : '批量'}}</button>
    </view>
    <view class="batch-bar" wx:if="{{batchMode}}">
      <view class="batch-left">
        <view class="batch-select-all" bindtap="selectAll">{{selectedIds.length === selectableCount ? '取消全选' : '全选'}}</view>
        <text class="batch-count">{{selectedIds.length}}/{{selectableCount}} 项</text>
      </view>
      <button class="btn btn-xs btn-blue" bindtap="showStatusDialog">更新状态</button>
    </view>
  </view>

  <view class="item-list">
    <view class="item-card" wx:for="{{filteredList}}" wx:key="id">
      <view class="item-top">
        <view class="item-top-left">
          <view class="sel-box {{item._sel ? 'on' : ''}}" wx:if="{{batchMode}}" bindtap="toggleSelect" data-id="{{item.id}}">
            <text class="check-icon">{{item._sel ? '✓' : ''}}</text>
          </view>
          <view class="item-name-wrap">
            <text class="item-order">#{{item.orderNo}}</text>
            <text class="item-name">{{item.name}}</text>
            <text class="item-source" wx:if="{{item.platform}}">📌 {{item.platform}}</text>
          </view>
        </view>
        <picker range="{{statusOptions}}" range-key="text" bindchange="onStatusChange" data-id="{{item.id}}">
          <view class="status-badge status-{{item.status}}">{{item.statusText}}</view>
        </picker>
      </view>

      <view class="item-meta">
        <view class="meta-col">
          <text class="m-label">成本</text>
          <text class="m-value">¥{{item.cost}}</text>
        </view>
        <view class="meta-col" wx:if="{{item.status !== 'sold'}}">
          <text class="m-label">预期卖价</text>
          <input class="m-input" type="digit" placeholder="输入预期卖价"
            value="{{item.expectedPrice || item.salePrice}}" bindblur="onExpectedPriceInput" data-id="{{item.id}}" />
        </view>
        <view class="meta-col" wx:else>
          <text class="m-label">卖价</text>
          <text class="m-value">¥{{item.salePrice}}</text>
        </view>
        <view class="meta-col">
          <text class="m-label">{{item.status !== 'sold' ? '预期利润' : '利润'}}</text>
          <text class="m-value profit">¥{{item.expectedProfit}}</text>
          <text class="m-rate">{{item.expectedRate}}</text>
        </view>
      </view>

      <view class="item-footer">
        <view class="item-actions">
          <button class="act-btn act-edit" bindtap="goToEdit" data-id="{{item.id}}">✏️ 编辑</button>
          <button class="act-btn act-del" bindtap="deleteItem" data-id="{{item.id}}">🗑️ 删除</button>
        </view>
      </view>
    </view>
  </view>

  <view class="empty-state" wx:if="{{filteredList.length === 0}}">
    <text class="empty-icon">🎉</text>
    <text class="empty-text">没有符合条件的商品</text>
  </view>

  <view class="fab" bindtap="goToAdd">＋</view>
</view>

<view class="modal-overlay {{showStatusModal ? 'show' : ''}}" bindtap="hideStatusDialog">
  <view class="modal-box" catchtap="preventBubble">
    <view class="modal-title">批量标记状态</view>
    <text class="modal-desc">将已选的 {{selectedIds.length}} 件商品标记为：</text>
    <view class="modal-options">
      <view class="modal-option {{batchStatus === 'selling' ? 'active' : ''}}" bindtap="setBatchStatus" data-status="selling">
        <text class="opt-icon">🟢</text>
        <text>在售中</text>
      </view>
      <view class="modal-option {{batchStatus === 'unsold' ? 'active' : ''}}" bindtap="setBatchStatus" data-status="unsold">
        <text class="opt-icon">🟠</text>
        <text>未售出</text>
      </view>
    </view>
    <view class="modal-actions">
      <button class="btn btn-ghost" bindtap="hideStatusDialog">取消</button>
      <button class="btn btn-primary" bindtap="confirmBatchUpdate">确认</button>
    </view>
  </view>
</view>

<view class="modal-overlay {{showSoldModal ? 'show' : ''}}" bindtap="cancelSold">
  <view class="modal-box" catchtap="preventBubble">
    <view class="modal-title">标记售出</view>
    <view class="input-group">
      <text class="input-label required">收款日期</text>
      <picker mode="date" value="{{soldReceiptDate}}" bindchange="onSoldDateChange">
        <view class="picker-field">{{soldReceiptDate}}</view>
      </picker>
      <text class="hint" wx:if="{{soldDateFuture}}" style="color:#fa5151">收款日期不能超过今天，请重新选择</text>
      <text class="hint" wx:elif="{{soldDateInValid}}" style="color:#fa5151">收款日期不能早于付款日期（{{soldPaymentDate}}）</text>
      <text class="hint" wx:elif="{{!soldPaymentDate}}">未设置付款日期</text>
      <text class="hint" wx:else>付款日期 {{soldPaymentDate}}</text>
    </view>
    <view class="modal-actions">
      <button class="btn btn-ghost" bindtap="cancelSold">取消</button>
      <button class="btn btn-primary" bindtap="confirmSold">确认售出</button>
    </view>
  </view>
</view>
