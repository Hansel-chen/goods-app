<view class="page">
  <form bindsubmit="onSubmit" report-submit>

    <view class="card">
      <view class="section-title">商品信息</view>

      <view class="input-group">
        <text class="input-label required">商品名称</text>
        <input class="input-field" name="name" placeholder="致态Ti600 1Tb硬盘" value="{{formData.name}}" />
      </view>

      <view class="input-group">
        <text class="input-label required">平台</text>
        <view class="platform-chips">
          <view class="platform-chip {{formData.platform === item ? 'on' : ''}}" wx:for="{{platformOptions}}" wx:key="*this" data-platform="{{item}}" bindtap="selectPlatform">{{item || '其他'}}</view>
        </view>
        <input class="input-field" name="platform" placeholder="点击上方或直接输入" value="{{formData.platform}}" />
      </view>

      <view class="input-group">
        <text class="input-label required">付款日期</text>
        <picker mode="date" value="{{formData.paymentDate}}" bindchange="onPaymentDateChange">
          <view class="picker-field">{{formData.paymentDate || '请选择'}}</view>
        </picker>
      </view>
    </view>

    <view class="card">
      <view class="section-title">金额信息</view>

      <view class="form-row">
        <view class="input-group flex-1">
          <text class="input-label required">成本</text>
          <input class="input-field" name="cost" type="digit" placeholder="0.00"
            value="{{formData.cost}}" data-field="cost" bindinput="onAmountInput" />
        </view>
        <view class="input-group flex-1">
          <text class="input-label required">卖价</text>
          <input class="input-field" name="salePrice" type="digit" placeholder="0.00"
            value="{{formData.salePrice}}" data-field="salePrice" bindinput="onAmountInput" />
        </view>
      </view>

      <view class="form-row">
        <view class="input-group flex-1">
          <text class="input-label">手续费</text>
          <input class="input-field" name="fee" type="digit" placeholder="0.00"
            value="{{formData.fee}}" data-field="fee" bindinput="onAmountInput" />
        </view>
        <view class="input-group flex-1">
          <text class="input-label">运费</text>
          <input class="input-field" name="shippingFee" type="digit" placeholder="0.00"
            value="{{formData.shippingFee}}" data-field="shippingFee" bindinput="onAmountInput" />
        </view>
      </view>

      <view class="profit-preview" wx:if="{{calculatedProfit !== '0.00'}}">
        <text class="profit-label">预计利润</text>
        <text class="profit-num {{calculatedProfit >= 0 ? 'text-green' : 'text-red'}}">{{calculatedProfit >= 0 ? '+' : ''}}¥{{calculatedProfit}} ({{calculatedProfitRate}})</text>
      </view>
    </view>

    <view class="card" wx:if="{{shareMembers.length > 0}}">
      <view class="section-title">分成比例</view>

      <view class="preset-bar">
        <text class="preset-label">快速方案</text>
        <scroll-view class="preset-scroll" scroll-x>
          <view class="preset-inner">
            <view class="preset-btn" wx:for="{{presets}}" wx:key="index"
              bindtap="onPresetSelect" data-index="{{index}}">{{item.label}}</view>
          </view>
        </scroll-view>
      </view>

      <view class="assign-hint" wx:if="{{pendingSlots}}">
        <text class="assign-text">分配: {{assignTarget}} — 点击成员分配</text>
        <text class="assign-cancel" bindtap="cancelAssign">取消</text>
      </view>
      <view class="share-inputs">
        <view class="share-row" wx:for="{{shareMembers}}" wx:key="id" bindtap="assignSlot" data-id="{{item.id}}">
          <view class="share-badge {{parseFloat(formData[item.id + 'Ratio']) > 0 ? 'assigned' : ''}} {{pendingSlots ? 'selectable' : ''}}">
            <text class="badge-num">{{parseFloat(formData[item.id + 'Ratio']) > 0 ? formData[item.id + 'Ratio'] + '%' : (pendingSlots ? '+' : '')}}</text>
          </view>
          <text class="share-label">{{item.name}}</text>
          <view class="share-control">
            <input class="input-field share-input" name="{{item.id}}Ratio" type="digit"
              placeholder="0" value="{{formData[item.id + 'Ratio']}}"
              data-field="{{item.id}}Ratio" bindinput="onRatioInput" catchtap />
            <text class="share-pct">%</text>
          </view>
          <text class="share-amount">¥{{calculatedShares[item.id]}}</text>
        </view>
      </view>
    </view>

    <view class="form-actions">
      <button class="btn btn-primary btn-block" formType="submit">✓ 提交记录</button>
      <button class="btn btn-ghost btn-block" bindtap="onCancel">取消</button>
    </view>
  </form>
</view>
