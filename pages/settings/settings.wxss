.page {
  padding: 20rpx 20rpx 100rpx;
}

.header-bar {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.header-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a1a;
}
.header-desc {
  display: block;
  font-size: 22rpx;
  color: #c0c0c0;
  margin-top: 8rpx;
  line-height: 1.5;
}

.section-label {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 26rpx;
  font-weight: 600;
  color: #8c8c8c;
  margin-bottom: 12rpx;
  padding: 0 4rpx;
}
.section-label.muted { color: #c0c0c0; }
.section-count {
  font-size: 22rpx;
  font-weight: 400;
}

.member-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.member-card.inactive { opacity: 0.6; }

.member-left {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.member-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
}
.member-avatar.disabled { background: #d0d0d0 !important; }

.member-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a1a;
}
.member-name.disabled { color: #8c8c8c; }

.add-bar {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx 20rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  border: 2rpx dashed #eee;
}
.add-bar:active { background: #f9f9f9; }

.add-icon {
  font-size: 32rpx;
  color: #07c160;
  font-weight: 700;
}
.add-text {
  font-size: 28rpx;
  color: #07c160;
  font-weight: 500;
}

.footer-actions {
  margin-top: 40rpx;
  display: flex;
  justify-content: center;
}
.footer-btn {
  padding: 16rpx 40rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #8c8c8c;
  border: none;
}
.footer-btn:active { background: #e8e8e8; }

.modal-input {
  width: 100%;
  padding: 22rpx 24rpx;
  border: 2rpx solid #eee;
  border-radius: 8rpx;
  font-size: 28rpx;
  margin-bottom: 8rpx;
  box-sizing: border-box;
}
.flex-1 { flex: 1; }
