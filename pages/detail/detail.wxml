<!-- pages/detail/detail.wxml -->
<view class="page">

  <!-- 头部 -->
  <view class="head-bar">
    <view class="head-top">
      <text class="head-name">{{item.name}}</text>
      <view class="head-status">
        <text class="status-dot {{item.status}}"></text>
        <text>{{item.statusText}}</text>
      </view>
    </view>
    <text class="head-platform">{{item.platform}}</text>
  </view>

  <!-- 核心数据卡片 -->
  <view class="core-card">
    <view class="core-block">
      <text class="core-num {{item.profitType === 'profit' ? 'text-green' : (item.profitType === 'loss' ? 'text-red' : '')}}">¥{{item.profit}}</text>
      <text class="core-lbl">
        <text class="status-dot {{item.profitType === 'profit' ? 'selling' : (item.profitType === 'loss' ? 'unsold' : 'sold')}}"></text>
        利润 ({{item.profitRate}})
      </text>
    </view>
    <view class="core-line"></view>
    <view class="core-block">
      <text class="core-num">¥{{item.cost}}</text>
      <text class="core-lbl">成本</text>
    </view>
    <view class="core-line"></view>
    <view class="core-block">
      <text class="core-num">¥{{item.salePrice}}</text>
      <text class="core-lbl">卖价</text>
    </view>
  </view>

  <!-- 补充信息卡（日期、手续费、运费） -->
  <view class="supplement-card">
    <view class="supplement-grid">
      <view class="supplement-item">
        <text class="s-label">付款日期</text>
        <text class="s-value">{{item.paymentDate || '-'}}</text>
      </view>
      <view class="supplement-item">
        <text class="s-label">收款日期</text>
        <text class="s-value">{{item.receiptDate || '未收款'}}</text>
      </view>
      <view class="supplement-item">
        <text class="s-label">手续费</text>
        <text class="s-value">¥{{item.fee || '0.00'}}</text>
      </view>
      <view class="supplement-item">
        <text class="s-label">运费</text>
        <text class="s-value">¥{{item.shippingFee || '0.00'}}</text>
      </view>
    </view>
  </view>

  <!-- 分成信息 -->
  <view class="share-card" wx:if="{{shareMembers.length > 0}}">
    <view class="share-title">分成</view>
    <view class="share-row" wx:for="{{shareMembers}}" wx:key="id">
      <text class="share-name">{{item.name}}</text>
      <text class="share-pct">{{item.ratio}}</text>
      <text class="share-amount">¥{{item.share}}</text>
    </view>
    <view class="share-remark" wx:if="{{item.remark}}">
      <text class="remark-text">{{item.remark}}</text>
    </view>
  </view>


</view>
