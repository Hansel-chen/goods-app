.page {
  padding: 20rpx 20rpx 100rpx;
}

/* 头部 */
.head-bar {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 20rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.head-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.head-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a1a;
  flex: 1;
  margin-right: 12rpx;
}
.head-platform {
  display: inline-block;
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #8c8c8c;
  background: #f5f5f5;
  padding: 4rpx 14rpx;
  border-radius: 4rpx;
}

/* 核心数据 */
.core-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 16rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
  display: flex;
  align-items: center;
}
.core-block {
  flex: 1;
  text-align: center;
}
.core-num {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #1a1a1a;
}
.text-green { color: #07c160; }
.text-red { color: #fa5151; }
.core-lbl {
  display: block;
  font-size: 20rpx;
  color: #8c8c8c;
  margin-top: 6rpx;
}
.core-line {
  width: 2rpx;
  height: 48rpx;
  background: #eee;
}

/* 补充信息 */
.supplement-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.supplement-grid {
  display: flex;
  flex-wrap: wrap;
}
.supplement-item {
  width: 50%;
  display: flex;
  justify-content: space-between;
  padding: 10rpx 0;
}
.s-label {
  font-size: 24rpx;
  color: #8c8c8c;
}
.s-value {
  font-size: 24rpx;
  font-weight: 600;
  color: #1a1a1a;
}

/* 分成 */
.share-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx 20rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.share-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #8c8c8c;
  margin-bottom: 12rpx;
}
.share-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 10rpx 0;
}
.share-row + .share-row {
  border-top: 2rpx solid #eee;
}
.share-name {
  width: 60rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: #1a1a1a;
}
.share-pct {
  flex: 1;
  font-size: 22rpx;
  color: #8c8c8c;
}
.share-amount {
  font-size: 24rpx;
  font-weight: 700;
  color: #07c;
}
.share-remark {
  margin-top: 12rpx;
  padding: 12rpx 14rpx;
  background: #f9f9f9;
  border-radius: 8rpx;
}
.remark-text {
  font-size: 22rpx;
  color: #c0c0c0;
  line-height: 1.5;
}

