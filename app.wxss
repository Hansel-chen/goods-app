page {
  background-color: #f5f6fa;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  font-size: 28rpx;
  color: #1a1a1a;
  line-height: 1.5;
}

.container {
  padding: 20rpx;
}

.card {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 24rpx;
  padding-left: 18rpx;
  border-left: 6rpx solid #07c160;
  line-height: 1.4;
}

.tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 6rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.tag-green { background: #e8f8ee; color: #07c160; }
.tag-blue { background: #e8f4ff; color: #1989fa; }
.tag-orange { background: #fff3e0; color: #ff9300; }
.tag-red { background: #ffeeee; color: #fa5151; }
.tag-gray { background: #f5f5f5; color: #8c8c8c; }

.status-dot {
  display: inline-block;
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  margin-right: 6rpx;
}
.status-dot.sold { background: #b0b0b0; }
.status-dot.unsold { background: #ff9300; }
.status-dot.selling { background: #07c160; }

.price { color: #fa5151; font-weight: 600; }
.profit { color: #07c160; font-weight: 600; }

button {
  margin: 0;
  padding: 0;
  line-height: 1.5;
  background: transparent;
  color: inherit;
}
button::after { border: none; }

.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 18rpx 32rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 500;
  border: none;
}
.btn:active { opacity: 0.8; }

.btn-primary { background: #07c160; color: #fff; }
.btn-blue { background: #1989fa; color: #fff; }
.btn-danger { background: #fa5151; color: #fff; }
.btn-outline { background: transparent; border: 2rpx solid #eee; color: #1a1a1a; }
.btn-ghost { background: #f5f5f5; color: #8c8c8c; }

.btn-sm { padding: 12rpx 24rpx; font-size: 24rpx; border-radius: 8rpx; }
.btn-xs { padding: 8rpx 16rpx; font-size: 22rpx; border-radius: 6rpx; }
.btn-orange { background: #ff9300; color: #fff; }
.btn-block { width: 100%; }

.fab {
  position: fixed;
  right: 32rpx;
  bottom: 120rpx;
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
  background: #07c160;
  color: #fff;
  font-size: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(7, 193, 96, 0.4);
  z-index: 50;
  border: none;
}
.fab:active { opacity: 0.8; }

.input-group {
  margin-bottom: 28rpx;
}
.input-label {
  display: block;
  font-size: 26rpx;
  color: #8c8c8c;
  margin-bottom: 10rpx;
  font-weight: 500;
}
.input-label.required::before {
  content: '*';
  color: #fa5151;
  margin-right: 4rpx;
}
.input-field {
  width: 100%;
  height: 72rpx;
  padding: 0 24rpx;
  border: 2rpx solid #eee;
  border-radius: 8rpx;
  font-size: 28rpx;
  line-height: 72rpx;
  background: #fafafa;
  color: #1a1a1a;
  box-sizing: border-box;
}
.input-field:focus {
  border-color: #07c160;
  background: #fff;
}
.picker-field {
  height: 72rpx;
  padding: 0 24rpx;
  border: 2rpx solid #eee;
  border-radius: 8rpx;
  font-size: 28rpx;
  line-height: 72rpx;
  background: #fafafa;
  color: #1a1a1a;
  box-sizing: border-box;
}
.textarea-field {
  width: 100%;
  min-height: 140rpx;
  padding: 20rpx 24rpx;
  border: 2rpx solid #eee;
  border-radius: 8rpx;
  font-size: 28rpx;
  line-height: 1.5;
  background: #fafafa;
  box-sizing: border-box;
}

.empty-state {
  padding: 120rpx 40rpx;
  text-align: center;
}
.empty-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 20rpx;
  opacity: 0.3;
}
.empty-text {
  font-size: 28rpx;
  color: #c0c0c0;
}

.hint {
  display: block;
  font-size: 22rpx;
  color: #c0c0c0;
  margin-top: 8rpx;
}
.hint-success { color: #07c160; }
.hint-danger { color: #fa5151; }

.filter-bar {
  display: flex;
  gap: 12rpx;
  margin-bottom: 0;
}
.filter-tab {
  flex: 1;
  text-align: center;
  padding: 14rpx 0;
  border-radius: 12rpx;
  font-size: 26rpx;
  font-weight: 500;
  background: #f0f0f0;
  color: #8c8c8c;
}
.filter-tab.active {
  background: #07c160;
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(7, 193, 96, 0.3);
}

.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.45);
  display: none;
  align-items: center;
  justify-content: center;
  z-index: 200;
}
.modal-overlay.show { display: flex; }
.modal-box {
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx 36rpx;
  width: 620rpx;
  max-height: 70vh;
  overflow-y: auto;
}
.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
  margin-bottom: 24rpx;
}
.modal-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 32rpx;
}
.modal-actions .btn { flex: 1; }

.divider {
  height: 2rpx;
  background: #eee;
  margin: 20rpx 0;
}

::-webkit-scrollbar {
  width: 0;
  height: 0;
  color: transparent;
}
